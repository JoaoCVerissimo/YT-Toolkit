{
  "name": "yt-toolkit",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "electron:dev": "electron .",
    "electron:clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "electron:prebuild": "npm run electron:clean && next build && node scripts/prepare-electron.js",
    "electron:build:mac": "node scripts/download-binaries.js mac-arm64 && npm run electron:prebuild && electron-builder --mac",
    "electron:build:win": "node scripts/download-binaries.js win-x64 && npm run electron:prebuild && electron-builder --win"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "ffmpeg-static": "^5.3.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "youtube-dl-exec": "^3.1.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
